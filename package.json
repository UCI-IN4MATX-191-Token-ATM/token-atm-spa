        "@angular/forms": "^19.2.15",
        "@angular/localize": "^19.2.15",
        "@angular/material": "~19.2.19",
        "@angular/platform-browser": "^19.2.15",
        "@angular/platform-browser-dynamic": "^19.2.15",
        "@angular/router": "^19.2.15",
        "@popperjs/core": "^2.11.6",
        "ag-grid-angular": "^32.3.9",
        "ag-grid-community": "^32.3.9",
        "axios": "^1.11.0",
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "camelcase-keys": "^8.0.2",
        "compress-json": "^2.1.2",
        "date-fns": "^2.30.0",
        "date-fns-tz": "^2.0.1",
        "decamelize-keys": "^2.0.1",
        "flatted": "^3.3.3",
        "fp-ts": "^2.16.11",
        "html-dom-parser": "^3.1.7",
        "io-ts": "^2.2.22",
        "js-base64": "^3.7.8",
        "jszip": "^3.10.1",
        "lodash": "^4.17.21",
        "ngx-bootstrap": "^19.0.0",
        "ngx-mat-select-search": "^8.0.3",
        "papaparse": "^5.5.3",
        "rxjs": "~7.8.0",
        "sanitize-filename": "^1.6.3",
